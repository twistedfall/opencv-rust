From c79fc76be0830dd0f5aaad155eed9f7f6f3cbe83 Mon Sep 17 00:00:00 2001
From: Haris-bin-shakeel07 <muhammadharis.tech4@gmail.com>
Date: Mon, 8 Jun 2026 01:24:49 +0500
Subject: [PATCH 1/2] objc: Fix VolumeType enum name clash on macOS

---
 modules/objc/generator/gen_objc.py      | 6 +++++-
 modules/ptcloud/misc/objc/gen_dict.json | 7 +++++++
 2 files changed, 12 insertions(+), 1 deletion(-)
 create mode 100644 modules/ptcloud/misc/objc/gen_dict.json

diff --git a/modules/objc/generator/gen_objc.py b/modules/objc/generator/gen_objc.py
index 78fe9454bcb6..ac0e551b5205 100755
--- a/modules/objc/generator/gen_objc.py
+++ b/modules/objc/generator/gen_objc.py
@@ -847,7 +847,11 @@ def add_enum(self, decl): # [ "enum cname", "", [], [] ]
             objc_type = enumType.rsplit(".", 1)[-1]
             if objc_type in enum_ignore_list:
                 return
-            if constinfo.classname in enum_fix:
+            if not constinfo.classname:
+                module_fix = enum_fix.get(self.Module, {})
+                objc_type = module_fix.get(objc_type, objc_type)
+                objc_type = enum_fix.get(objc_type, objc_type)
+            elif constinfo.classname in enum_fix:
                 objc_type = enum_fix[constinfo.classname].get(objc_type, objc_type)
             import_module = constinfo.classname if constinfo.classname and constinfo.classname != objc_type else self.Module
             type_dict[ctype] = { "cast_from" : "int",
diff --git a/modules/ptcloud/misc/objc/gen_dict.json b/modules/ptcloud/misc/objc/gen_dict.json
new file mode 100644
index 000000000000..d39cca2c9ada
--- /dev/null
+++ b/modules/ptcloud/misc/objc/gen_dict.json
@@ -0,0 +1,7 @@
+{
+  "enum_fix": {
+    "Ptcloud": {
+      "VolumeType": "PtcloudVolumeType"
+    }
+  }
+}

From 8060a81aad74f03055a9430600f03b76c662fe67 Mon Sep 17 00:00:00 2001
From: Alexander Smorkalov <alexander.smorkalov@opencv.ai>
Date: Wed, 10 Jun 2026 10:49:19 +0300
Subject: [PATCH 2/2] objc: fix enum class rename and import_module for
 namespace-level enums in gen_objc.py

---
 modules/objc/generator/gen_objc.py      | 5 +++--
 modules/ptcloud/misc/objc/gen_dict.json | 2 +-
 2 files changed, 4 insertions(+), 3 deletions(-)

diff --git a/modules/objc/generator/gen_objc.py b/modules/objc/generator/gen_objc.py
index ac0e551b5205..954470256456 100755
--- a/modules/objc/generator/gen_objc.py
+++ b/modules/objc/generator/gen_objc.py
@@ -847,13 +847,14 @@ def add_enum(self, decl): # [ "enum cname", "", [], [] ]
             objc_type = enumType.rsplit(".", 1)[-1]
             if objc_type in enum_ignore_list:
                 return
-            if not constinfo.classname:
+            original_objc_type = objc_type
+            if not constinfo.classname or constinfo.classname == objc_type:
                 module_fix = enum_fix.get(self.Module, {})
                 objc_type = module_fix.get(objc_type, objc_type)
                 objc_type = enum_fix.get(objc_type, objc_type)
             elif constinfo.classname in enum_fix:
                 objc_type = enum_fix[constinfo.classname].get(objc_type, objc_type)
-            import_module = constinfo.classname if constinfo.classname and constinfo.classname != objc_type else self.Module
+            import_module = constinfo.classname if constinfo.classname and constinfo.classname != original_objc_type else self.Module
             type_dict[ctype] = { "cast_from" : "int",
                                  "cast_to" : get_cname(enumType),
                                  "objc_type" : objc_type,
diff --git a/modules/ptcloud/misc/objc/gen_dict.json b/modules/ptcloud/misc/objc/gen_dict.json
index d39cca2c9ada..22a5288d0f29 100644
--- a/modules/ptcloud/misc/objc/gen_dict.json
+++ b/modules/ptcloud/misc/objc/gen_dict.json
@@ -1,7 +1,7 @@
 {
   "enum_fix": {
     "Ptcloud": {
-      "VolumeType": "PtcloudVolumeType"
+      "VolumeType": "CV_VolumeType"
     }
   }
 }
